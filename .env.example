# WeatherInsight Indonesia — Environment Variables
# Salin file ini ke .env (lokal) atau isi di dashboard deploy masing-masing.

# ── Database (Supabase PostgreSQL) ────────────────────────────────────
# Dipakai oleh: backend FastAPI dan scraper yang dipanggil endpoint cron
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Backend (Render) ──────────────────────────────────────────────────
# CORS origins — domain frontend yang diizinkan akses API.
# Pisahkan dengan koma kalau lebih dari satu.
CORS_ORIGINS=https://weatherinsight.vercel.app,http://localhost:3000

# Token endpoint internal POST /api/jobs/hourly.
# Gunakan nilai acak panjang yang sama di Render dan header cron-job.org.
CRON_SECRET=change-me-with-a-long-random-value

# ── Frontend (Vercel) ─────────────────────────────────────────────────
# URL backend FastAPI — ganti dengan URL Render setelah deploy.
NEXT_PUBLIC_BACKEND_URL=https://weatherinsight-api.onrender.com
